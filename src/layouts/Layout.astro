---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  page?: string;
}

const { title, page = '' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="corporate">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Taskrunner</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
  </head>
  <body class="min-h-screen bg-base-200">
    <Navbar page={page} />
    <main class="container mx-auto px-4 py-6 max-w-7xl">
      <slot />
    </main>
  </body>
</html>

<script>
  // Apply saved theme on load
  const saved = localStorage.getItem('theme');
  if (saved) {
    document.documentElement.setAttribute('data-theme', saved);
    const cb = document.getElementById('theme-checkbox') as HTMLInputElement;
    if (cb && saved === 'dark') cb.checked = true;
  }
</script>
