---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Case Report" page="case">
  <!-- Loading state -->
  <div id="loading-state" class="flex justify-center items-center h-64">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <!-- Not found state -->
  <div id="not-found" class="hidden">
    <div class="hero bg-base-100 rounded-2xl shadow py-16 px-6">
      <div class="hero-content text-center flex-col">
        <div class="text-7xl mb-2 select-none">🔍</div>
        <h2 class="text-2xl font-bold mb-2">Case Not Found</h2>
        <p class="text-base-content/50 max-w-sm mb-6">The requested case could not be found.</p>
        <a href={`${base}/cases`} class="btn btn-primary">Back to Cases</a>
      </div>
    </div>
  </div>

  <!-- Case report content -->
  <div id="case-content" class="hidden space-y-6">
    <!-- Action bar -->
    <div class="flex flex-wrap gap-2 no-print">
      <button id="print-btn" class="btn btn-outline btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        Print / PDF
      </button>
      <a href={`${base}/cases`} class="btn btn-ghost btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Cases
      </a>
    </div>

    <!-- Case header -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="badge badge-primary badge-outline">Case Report</span>
            </div>
            <h1 id="case-title" class="text-2xl font-bold mb-1"></h1>
            <p id="case-desc" class="text-base-content/60 text-sm hidden"></p>
          </div>
          <div class="text-sm space-y-1 text-right text-base-content/60">
            <div><span class="text-base-content/50">Created:</span> <span id="case-created" class="font-medium"></span></div>
            <div><span class="text-base-content/50">Runs:</span> <span id="case-run-count" class="font-medium"></span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Aggregate stats -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">Aggregate Summary</h2>
        <div class="flex flex-wrap gap-6 items-center">
          <div id="agg-pass-rate-radial" class="flex flex-col items-center gap-1">
            <div
              id="agg-pass-rate-circle"
              class="radial-progress font-bold"
              style="--value:0; --size:6rem; --thickness:0.5rem"
              role="progressbar"
            >0%</div>
            <div class="text-xs text-base-content/40 font-medium uppercase tracking-wide">Pass Rate</div>
          </div>
          <div class="flex-1 min-w-0">
            <div class="stats stats-horizontal shadow flex-wrap w-full">
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Total Runs</div>
                <div class="stat-value text-2xl text-primary" id="agg-runs">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Total Steps</div>
                <div class="stat-value text-2xl" id="agg-steps">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Pass</div>
                <div class="stat-value text-2xl text-success" id="agg-pass">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Fail</div>
                <div class="stat-value text-2xl text-error" id="agg-fail">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">N/A</div>
                <div class="stat-value text-2xl text-warning" id="agg-na">0</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Runs in this case -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">Runs</h2>
        <div id="case-runs-empty" class="hidden text-base-content/40 text-sm py-4 text-center">No runs assigned to this case yet.</div>
        <div id="case-runs-list" class="space-y-4"></div>
      </div>
    </div>
  </div>
</Layout>

<style>
  @media print {
    .no-print { display: none !important; }
    .card { break-inside: avoid; }
    nav, header, [data-navbar] { display: none !important; }
    @page { margin: 1.5cm 1.5cm 2.5cm; }
  }
</style>

<script>
  import { getCaseById } from '../services/caseService.ts';
  import { getRunById, getRunHistory, formatDuration } from '../services/runService.ts';

  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const params = new URLSearchParams(window.location.search);
  const caseId = params.get('id');

  const loadingEl = document.getElementById('loading-state')!;
  const notFoundEl = document.getElementById('not-found')!;
  const contentEl = document.getElementById('case-content')!;

  function formatDate(iso: string) {
    return new Date(iso).toLocaleString();
  }

  function renderCaseReport() {
    if (!caseId) { showNotFound(); return; }
    const caseObj = getCaseById(caseId);
    if (!caseObj) { showNotFound(); return; }

    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    // Header
    (document.getElementById('case-title') as HTMLElement).textContent = caseObj.name;
    const descEl = document.getElementById('case-desc')!;
    if (caseObj.description) {
      descEl.textContent = caseObj.description;
      descEl.classList.remove('hidden');
    }
    (document.getElementById('case-created') as HTMLElement).textContent = new Date(caseObj.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
    (document.getElementById('case-run-count') as HTMLElement).textContent = String(caseObj.runIds.length);

    // Load runs
    const summaries = getRunHistory();
    const caseRunSummaries = summaries.filter(s => caseObj.runIds.includes(s.runId));

    // Aggregate stats
    let totalSteps = 0, totalPass = 0, totalFail = 0, totalNa = 0;
    for (const s of caseRunSummaries) {
      totalSteps += s.stepCount;
      totalPass += s.passCount;
      totalFail += s.failCount;
      totalNa += s.naCount;
    }
    (document.getElementById('agg-runs') as HTMLElement).textContent = String(caseRunSummaries.length);
    (document.getElementById('agg-steps') as HTMLElement).textContent = String(totalSteps);
    (document.getElementById('agg-pass') as HTMLElement).textContent = String(totalPass);
    (document.getElementById('agg-fail') as HTMLElement).textContent = String(totalFail);
    (document.getElementById('agg-na') as HTMLElement).textContent = String(totalNa);

    const totalToggle = totalPass + totalFail;
    const passRate = totalToggle > 0 ? Math.round((totalPass / totalToggle) * 100) : 0;
    const passRateEl = document.getElementById('agg-pass-rate-circle')!;
    if (totalToggle === 0) {
      document.getElementById('agg-pass-rate-radial')?.classList.add('hidden');
    } else {
      const color = passRate >= 80 ? 'text-success' : passRate >= 50 ? 'text-warning' : 'text-error';
      passRateEl.className = `radial-progress font-bold ${color}`;
      passRateEl.style.setProperty('--value', String(passRate));
      passRateEl.textContent = `${passRate}%`;
    }

    // Run cards
    const runsListEl = document.getElementById('case-runs-list')!;
    const runsEmptyEl = document.getElementById('case-runs-empty')!;

    if (caseRunSummaries.length === 0) {
      runsEmptyEl.classList.remove('hidden');
      return;
    }

    const sorted = [...caseRunSummaries].sort(
      (a, b) => new Date(a.startedAt).getTime() - new Date(b.startedAt).getTime()
    );

    sorted.forEach((summary, idx) => {
      const run = getRunById(summary.runId);
      const dur = formatDuration(
        new Date(summary.completedAt).getTime() - new Date(summary.startedAt).getTime()
      );
      const date = new Date(summary.startedAt).toLocaleDateString(undefined, { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
      const time = new Date(summary.startedAt).toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });

      const passRate = (summary.passCount + summary.failCount) > 0
        ? Math.round((summary.passCount / (summary.passCount + summary.failCount)) * 100)
        : null;

      const outcomeLabel = summary.failCount === 0 ? { label: 'All Pass', cls: 'badge-success' }
        : summary.passCount === 0 ? { label: 'Needs Review', cls: 'badge-error' }
        : { label: 'Mixed', cls: 'badge-warning' };

      // Build step timeline if run data available
      let stepsHtml = '';
      if (run) {
        stepsHtml = `
          <div class="mt-4">
            <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide mb-2">Step Details</div>
            <div class="overflow-x-auto">
              <table class="table table-xs w-full">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Step</th>
                    <th>Status</th>
                    <th>Pass</th>
                    <th>Fail</th>
                    <th>N/A</th>
                    <th>Notes</th>
                  </tr>
                </thead>
                <tbody>
                  ${run.steps.map((step, si) => {
                    let p = 0, f = 0, n = 0;
                    const allCaptured = [...step.captured, ...step.subtasks.flatMap(sub => sub.captured)];
                    for (const c of allCaptured) {
                      if (c.value === 'Pass') p++;
                      else if (c.value === 'Fail') f++;
                      else if (c.value === 'N-A') n++;
                    }
                    const statusCls = step.status === 'complete' ? 'text-success' : step.status === 'skipped' ? 'text-warning' : 'text-base-content/40';
                    return `<tr>
                      <td class="text-xs text-base-content/40">${si + 1}</td>
                      <td class="font-medium text-xs">${escHtml(step.title)}</td>
                      <td class="text-xs ${statusCls}">${step.status}</td>
                      <td class="text-xs font-semibold text-success">${p || ''}</td>
                      <td class="text-xs font-semibold text-error">${f || ''}</td>
                      <td class="text-xs font-semibold text-warning">${n || ''}</td>
                      <td class="text-xs text-base-content/50">${step.notes ? escHtml(step.notes) : ''}</td>
                    </tr>`;
                  }).join('')}
                </tbody>
              </table>
            </div>
          </div>`;
      }

      const card = document.createElement('div');
      card.className = 'border border-base-200 rounded-xl overflow-hidden';
      card.innerHTML = `
        <div class="collapse collapse-arrow bg-base-100">
          <input type="checkbox" />
          <div class="collapse-title p-4">
            <div class="flex items-start gap-4 flex-wrap">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <span class="text-xs font-mono text-base-content/40">Run ${idx + 1}</span>
                  <span class="badge ${outcomeLabel.cls} badge-sm">${outcomeLabel.label}</span>
                  <span class="text-xs text-base-content/30 font-mono">${summary.runId.slice(0, 8)}…</span>
                </div>
                <div class="font-bold text-sm">${escHtml(summary.templateName)}</div>
                <div class="flex items-center gap-3 flex-wrap mt-1 text-xs text-base-content/50">
                  <span>${escHtml(summary.operatorName)}</span>
                  <span>${date} · ${time}</span>
                  <span>${dur}</span>
                </div>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                ${passRate !== null ? `
                  <div class="radial-progress text-success text-xs font-bold" style="--value:${passRate}; --size:3rem; --thickness:0.3rem" role="progressbar">${passRate}%</div>
                ` : ''}
                <div class="grid grid-cols-3 gap-1 text-center">
                  <div class="bg-success/10 rounded-lg px-2 py-1">
                    <div class="text-xs font-bold text-success">${summary.passCount}</div>
                    <div class="text-xs text-success/60">P</div>
                  </div>
                  <div class="bg-error/10 rounded-lg px-2 py-1">
                    <div class="text-xs font-bold text-error">${summary.failCount}</div>
                    <div class="text-xs text-error/60">F</div>
                  </div>
                  <div class="bg-warning/10 rounded-lg px-2 py-1">
                    <div class="text-xs font-bold text-warning">${summary.naCount}</div>
                    <div class="text-xs text-warning/60">N</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="collapse-content px-4 pb-4">
            <div class="flex gap-2 mb-3 no-print">
              <a href="${base}/report?run=${summary.runId}" class="btn btn-xs btn-ghost gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Full Report
              </a>
            </div>
            ${stepsHtml || '<div class="text-xs text-base-content/40">Run detail not available.</div>'}
          </div>
        </div>
      `;
      runsListEl.appendChild(card);
    });

    // Print
    document.getElementById('print-btn')?.addEventListener('click', () => {
      document.documentElement.setAttribute('data-print-date', new Date().toLocaleDateString());
      window.print();
    });
  }

  function showNotFound() {
    loadingEl.classList.add('hidden');
    notFoundEl.classList.remove('hidden');
  }

  function escHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  renderCaseReport();
</script>
