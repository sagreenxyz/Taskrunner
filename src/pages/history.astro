---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Run History">
  <div class="mb-8 flex items-center justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold mb-1">Run History</h1>
      <p class="text-base-content/60">Past procedure runs with outcomes and reports.</p>
    </div>
    <a href={`${base}/`} class="btn btn-primary btn-sm gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Procedure
    </a>
  </div>

  <!-- Loading state -->
  <div id="loading-state" class="flex justify-center items-center h-40">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden">
    <div class="hero bg-base-100 rounded-2xl shadow py-16 px-6">
      <div class="hero-content text-center flex-col">
        <div class="text-7xl mb-2 select-none">📋</div>
        <h2 class="text-2xl font-bold mb-2">No Runs Yet</h2>
        <p class="text-base-content/50 max-w-sm mb-6">
          Complete your first procedure to see run history and reports here.
        </p>
        <a href={`${base}/`} class="btn btn-primary gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Start a Procedure
        </a>
      </div>
    </div>
  </div>

  <!-- History cards -->
  <div id="history-cards" class="hidden space-y-3" aria-live="polite"></div>

  <!-- Delete confirm modal -->
  <dialog id="delete-modal" class="modal">
    <div class="modal-box">
      <div class="flex items-center gap-3 mb-2">
        <div class="text-error text-3xl">🗑</div>
        <h3 class="font-bold text-lg text-error">Delete Run?</h3>
      </div>
      <div role="alert" class="alert alert-warning mb-3 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span>Deleted runs cannot be recovered. Consider exporting this run first.</span>
      </div>
      <p class="text-base-content/70 text-sm">This will permanently delete this run record. This cannot be undone.</p>
      <div class="modal-action flex-wrap gap-2">
        <button id="delete-cancel-btn" class="btn btn-ghost">Cancel</button>
        <button id="delete-export-btn" class="btn btn-outline btn-sm gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          Export JSON
        </button>
        <button id="delete-confirm-btn" class="btn btn-error gap-2">🗑 Delete</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</Layout>

<script>
  import { getRunHistory, deleteRun, getRunById, exportRunAsJSON, formatDuration } from '../services/runService.ts';

  const loadingEl = document.getElementById('loading-state');
  const emptyEl = document.getElementById('empty-state');
  const cardsEl = document.getElementById('history-cards');

  const base = import.meta.env.BASE_URL.replace(/\/$/, '');

  function getOutcomeLabel(passCount: number, failCount: number, total: number) {
    if (total === 0) return { label: 'No data', cls: 'badge-ghost' };
    if (failCount === 0) return { label: 'All Pass', cls: 'badge-success' };
    if (passCount === 0 && failCount > 0) return { label: 'Needs Review', cls: 'badge-error' };
    return { label: 'Mixed', cls: 'badge-warning' };
  }

  function renderHistory() {
    const summaries = getRunHistory().sort(
      (a, b) => new Date(b.startedAt).getTime() - new Date(a.startedAt).getTime()
    );

    loadingEl?.classList.add('hidden');

    if (summaries.length === 0) {
      emptyEl?.classList.remove('hidden');
      return;
    }

    cardsEl?.classList.remove('hidden');
    if (!cardsEl) return;
    cardsEl.innerHTML = '';

    summaries.forEach(summary => {
      const dur = formatDuration(
        new Date(summary.completedAt).getTime() - new Date(summary.startedAt).getTime()
      );
      const date = new Date(summary.startedAt).toLocaleDateString(undefined, { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
      const time = new Date(summary.startedAt).toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      const outcome = getOutcomeLabel(summary.passCount, summary.failCount, summary.passCount + summary.failCount + summary.naCount);
      const passRate = (summary.passCount + summary.failCount) > 0
        ? Math.round((summary.passCount / (summary.passCount + summary.failCount)) * 100)
        : null;

      const card = document.createElement('div');
      card.className = 'card bg-base-100 shadow hover:shadow-md transition-all border border-base-200';
      card.innerHTML = `
        <div class="card-body p-5">
          <div class="flex items-start gap-4 flex-wrap">
            <!-- Main info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="badge ${outcome.cls} badge-sm">${outcome.label}</span>
                <span class="text-xs text-base-content/40 font-mono">${summary.runId.slice(0, 8)}…</span>
              </div>
              <h3 class="font-bold text-base leading-snug truncate">${summary.templateName}</h3>
              <div class="flex items-center gap-3 mt-1 flex-wrap">
                <span class="flex items-center gap-1 text-sm text-base-content/60">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  ${summary.operatorName}
                </span>
                <span class="flex items-center gap-1 text-sm text-base-content/50">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  ${date} · ${time}
                </span>
                <span class="flex items-center gap-1 text-sm text-base-content/50">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  ${dur}
                </span>
              </div>
            </div>

            <!-- Stats -->
            <div class="flex items-center gap-3 shrink-0">
              ${passRate !== null ? `
                <div class="radial-progress text-success text-xs font-bold" style="--value:${passRate}; --size:3.5rem; --thickness:0.35rem" role="progressbar" aria-label="${passRate}% pass rate">
                  ${passRate}%
                </div>
              ` : ''}
              <div class="grid grid-cols-3 gap-1 text-center">
                <div class="bg-success/10 rounded-lg px-2 py-1">
                  <div class="text-sm font-bold text-success">${summary.passCount}</div>
                  <div class="text-xs text-success/60">Pass</div>
                </div>
                <div class="bg-error/10 rounded-lg px-2 py-1">
                  <div class="text-sm font-bold text-error">${summary.failCount}</div>
                  <div class="text-xs text-error/60">Fail</div>
                </div>
                <div class="bg-warning/10 rounded-lg px-2 py-1">
                  <div class="text-sm font-bold text-warning">${summary.naCount}</div>
                  <div class="text-xs text-warning/60">N/A</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Footer -->
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-base-200">
            <div class="flex items-center gap-2 text-xs text-base-content/40">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
              </svg>
              ${summary.stepCount} steps
            </div>
            <div class="flex gap-2">
              <a href="${base}/report?run=${summary.runId}" class="btn btn-sm btn-ghost gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Report
              </a>
              <button class="btn btn-sm btn-ghost text-error gap-2 delete-btn" data-run-id="${summary.runId}">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Delete
              </button>
            </div>
          </div>
        </div>
      `;
      cardsEl.appendChild(card);
    });

    // Delete buttons
    let pendingDeleteId: string | null = null;
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        pendingDeleteId = (btn as HTMLButtonElement).dataset.runId ?? null;
        console.log('[history] delete-btn clicked', { runId: pendingDeleteId });
        (document.getElementById('delete-modal') as HTMLDialogElement).showModal();
      });
    });

    document.getElementById('delete-confirm-btn')?.addEventListener('click', () => {
      console.log('[history] delete-confirm-btn clicked', { runId: pendingDeleteId });
      if (pendingDeleteId) {
        deleteRun(pendingDeleteId);
        (document.getElementById('delete-modal') as HTMLDialogElement).close();
        renderHistory();
      }
    });

    document.getElementById('delete-export-btn')?.addEventListener('click', () => {
      console.log('[history] delete-export-btn clicked', { runId: pendingDeleteId });
      if (pendingDeleteId) {
        const run = getRunById(pendingDeleteId);
        if (run) {
          exportRunAsJSON(run);
        } else {
          console.warn('[history] delete-export-btn: run not found', { runId: pendingDeleteId });
        }
      }
    });

    document.getElementById('delete-cancel-btn')?.addEventListener('click', () => {
      console.log('[history] delete-cancel-btn clicked');
      pendingDeleteId = null;
      (document.getElementById('delete-modal') as HTMLDialogElement).close();
    });
  }

  renderHistory();
</script>
