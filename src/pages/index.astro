---
import Layout from '../layouts/Layout.astro';
import { templateRegistry } from '../data/templates/index.ts';

const categories = [...new Set(templateRegistry.map(t => t.category))];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Home">
  <!-- Active run alert (populated by JS) -->
  <div id="active-run-alert" class="hidden mb-6">
    <div class="alert alert-info shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div>
        <h3 class="font-bold">Run in progress: <span id="active-run-name"></span></h3>
        <div class="text-sm">Started <span id="active-run-time"></span></div>
      </div>
      <div class="flex gap-2">
        <a id="resume-run-btn" href={`${base}/run`} class="btn btn-sm btn-primary">Resume</a>
        <button id="discard-run-btn" class="btn btn-sm btn-outline btn-error">Discard</button>
      </div>
    </div>
  </div>

  <!-- Discard confirmation modal -->
  <dialog id="discard-modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg text-error">Discard Active Run?</h3>
      <p class="py-4">This will permanently delete the in-progress run. This action cannot be undone.</p>
      <div class="modal-action">
        <button id="discard-cancel-btn" class="btn btn-ghost">Cancel</button>
        <button id="discard-confirm-btn" class="btn btn-error">Discard Run</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <!-- Start new run over existing run modal -->
  <dialog id="overwrite-modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg text-warning">Active Run Exists</h3>
      <p class="py-4">You already have a run in progress. Starting a new procedure will discard the current run. Do you want to continue?</p>
      <div class="modal-action">
        <button id="overwrite-cancel-btn" class="btn btn-ghost">Cancel</button>
        <button id="overwrite-confirm-btn" class="btn btn-warning">Discard &amp; Start New</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Procedure Launcher</h1>
    <p class="text-base-content/70">Select a procedure template to get started.</p>
  </div>

  {categories.map(category => {
    const templates = templateRegistry.filter(t => t.category === category);
    return (
      <div class="mb-10">
        <div class="divider text-lg font-semibold">{category}</div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
          {templates.map(template => (
            <div class="card bg-base-100 shadow-md hover:shadow-lg transition-shadow">
              <div class="card-body">
                <div class="flex items-start justify-between gap-2">
                  <h2 class="card-title text-lg">{template.name}</h2>
                  <span class="badge badge-primary badge-outline shrink-0">{template.category}</span>
                </div>
                <p class="text-base-content/70 text-sm flex-1">{template.description}</p>
                <div class="text-sm text-base-content/50 mt-2">
                  ⏱ ~{template.estimatedMinutes} min · {template.steps.length} steps
                </div>
                <div class="card-actions justify-end mt-4">
                  <button
                    class="btn btn-primary start-procedure-btn"
                    data-template-id={template.id}
                  >
                    Start Procedure
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  })}
</Layout>

<script define:vars={{ base }}>
  const ACTIVE_RUN_KEY = 'proc_run_active';

  function loadActiveRun() {
    try {
      const raw = localStorage.getItem(ACTIVE_RUN_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function discardActiveRun() {
    localStorage.removeItem(ACTIVE_RUN_KEY);
  }

  function timeAgo(isoString) {
    const ms = Date.now() - new Date(isoString).getTime();
    const minutes = Math.floor(ms / 60000);
    const hours = Math.floor(minutes / 60);
    if (hours > 0) return `${hours}h ${minutes % 60}m ago`;
    if (minutes > 0) return `${minutes}m ago`;
    return 'just now';
  }

  // Check for active run
  const activeRun = loadActiveRun();
  if (activeRun) {
    const alert = document.getElementById('active-run-alert');
    const nameEl = document.getElementById('active-run-name');
    const timeEl = document.getElementById('active-run-time');
    if (alert && nameEl && timeEl) {
      nameEl.textContent = activeRun.templateName;
      timeEl.textContent = timeAgo(activeRun.startedAt);
      alert.classList.remove('hidden');
    }
  }

  // Discard from alert
  document.getElementById('discard-run-btn')?.addEventListener('click', () => {
    console.log('[index] discard-run-btn clicked');
    document.getElementById('discard-modal').showModal();
  });

  document.getElementById('discard-confirm-btn')?.addEventListener('click', () => {
    console.log('[index] discard-confirm-btn clicked');
    discardActiveRun();
    document.getElementById('active-run-alert')?.classList.add('hidden');
    document.getElementById('discard-modal').close();
  });

  document.getElementById('discard-cancel-btn')?.addEventListener('click', () => {
    console.log('[index] discard-cancel-btn clicked');
    document.getElementById('discard-modal').close();
  });

  // Start procedure buttons
  let pendingTemplateId = null;

  document.querySelectorAll('.start-procedure-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const templateId = btn.dataset.templateId;
      console.log('[index] start-procedure-btn clicked', { templateId });
      const currentRun = loadActiveRun();

      if (!currentRun) {
        window.location.href = `${base}/run?template=${templateId}`;
      } else {
        pendingTemplateId = templateId;
        document.getElementById('overwrite-modal').showModal();
      }
    });
  });

  document.getElementById('overwrite-confirm-btn')?.addEventListener('click', () => {
    console.log('[index] overwrite-confirm-btn clicked', { pendingTemplateId });
    discardActiveRun();
    document.getElementById('overwrite-modal').close();
    if (pendingTemplateId) {
      window.location.href = `${base}/run?template=${pendingTemplateId}`;
    }
  });

  document.getElementById('overwrite-cancel-btn')?.addEventListener('click', () => {
    console.log('[index] overwrite-cancel-btn clicked');
    pendingTemplateId = null;
    document.getElementById('overwrite-modal').close();
  });
</script>
