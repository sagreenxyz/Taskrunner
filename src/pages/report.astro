---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Run Report">
  <!-- Loading state -->
  <div id="loading-state" class="flex justify-center items-center h-64">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <!-- Not found state -->
  <div id="not-found" class="hidden">
    <div class="hero bg-base-100 rounded-2xl shadow py-16 px-6">
      <div class="hero-content text-center flex-col">
        <div class="text-7xl mb-2 select-none">🔍</div>
        <h2 class="text-2xl font-bold mb-2">Run Not Found</h2>
        <p class="text-base-content/50 max-w-sm mb-6">The requested run report could not be found.</p>
        <a href={`${base}/`} class="btn btn-primary">Back to Home</a>
      </div>
    </div>
  </div>

  <!-- Report content -->
  <div id="report-content" class="hidden space-y-6">
    <!-- Action buttons (hidden in print) -->
    <div id="action-buttons" class="flex flex-wrap gap-2 no-print">
      <button id="print-btn" class="btn btn-outline btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        Print / PDF
      </button>
      <button id="export-json-btn" class="btn btn-outline btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        Export JSON
      </button>
      <button id="export-md-btn" class="btn btn-outline btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Export Markdown
      </button>
      <a href={`${base}/history`} class="btn btn-ghost btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to History
      </a>
    </div>

    <!-- Report Header -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span id="report-template" class="badge badge-primary badge-outline"></span>
              <span id="report-category" class="badge badge-ghost"></span>
            </div>
            <h1 id="report-title" class="text-2xl font-bold mb-1"></h1>
          </div>
          <div class="text-sm space-y-1 text-right">
            <div class="flex items-center justify-end gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span id="report-operator" class="font-medium"></span>
            </div>
            <div><span class="text-base-content/50">Started:</span> <span id="report-started" class="font-medium"></span></div>
            <div><span class="text-base-content/50">Completed:</span> <span id="report-completed" class="font-medium"></span></div>
            <div><span class="text-base-content/50">Duration:</span> <span id="report-duration" class="font-medium"></span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-4">Summary</h2>
        <div class="flex flex-wrap gap-6 items-center">
          <!-- Radial progress for pass rate -->
          <div id="pass-rate-radial" class="flex flex-col items-center gap-1">
            <div
              id="pass-rate-circle"
              class="radial-progress font-bold"
              style="--value:0; --size:6rem; --thickness:0.5rem"
              role="progressbar"
            >0%</div>
            <div class="text-xs text-base-content/40 font-medium uppercase tracking-wide">Pass Rate</div>
          </div>

          <!-- Step stats -->
          <div class="flex-1 min-w-0">
            <div class="stats stats-horizontal shadow flex-wrap w-full">
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Total Steps</div>
                <div class="stat-value text-2xl" id="sum-total">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Completed</div>
                <div class="stat-value text-2xl text-success" id="sum-completed">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Skipped</div>
                <div class="stat-value text-2xl text-warning" id="sum-skipped">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Pass</div>
                <div class="stat-value text-2xl text-success" id="sum-pass">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">Fail</div>
                <div class="stat-value text-2xl text-error" id="sum-fail">0</div>
              </div>
              <div class="stat py-3 px-4">
                <div class="stat-title text-xs">N/A</div>
                <div class="stat-value text-2xl text-warning" id="sum-na">0</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Runtime-added steps callout -->
        <div id="runtime-steps-alert" class="hidden mt-4">
          <div class="alert alert-warning border border-warning/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
              <h3 class="font-bold text-sm">Steps Added at Runtime</h3>
              <div id="runtime-steps-list" class="text-sm opacity-80"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step Details — Timeline -->
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body">
        <h2 class="card-title text-lg mb-6">Step Details</h2>
        <ul id="steps-timeline" class="timeline timeline-vertical timeline-compact"></ul>
      </div>
    </div>
  </div>
</Layout>

<style>
  @media print {
    .no-print { display: none !important; }
    .timeline-box { break-inside: avoid; }
  }

  /* Expand all timeline content for print */
  @media print {
    .collapse-content { display: block !important; }
  }

  @media print {
    /* Hide the navbar */
    nav, header, [data-navbar] { display: none !important; }

    /* Ensure full-width layout */
    body { margin: 0; padding: 0; }

    /* Keep cards from splitting across pages */
    .card { break-inside: avoid; }

    /* Page footer */
    @page {
      margin: 1.5cm 1.5cm 2.5cm;
      @bottom-center {
        content: "Generated by Taskrunner — " attr(data-print-date);
        font-size: 9pt;
        color: #888;
      }
    }
  }
</style>

<script>
  import {
    getRunById,
    exportRunAsJSON,
    exportRunAsMarkdown,
    formatDuration,
  } from '../services/runService.ts';

  const params = new URLSearchParams(window.location.search);
  const runId = params.get('run');

  const loadingEl = document.getElementById('loading-state');
  const notFoundEl = document.getElementById('not-found');
  const reportEl = document.getElementById('report-content');

  function showNotFound() {
    loadingEl?.classList.add('hidden');
    notFoundEl?.classList.remove('hidden');
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleString();
  }

  function renderReport() {
    if (!runId) { showNotFound(); return; }

    const run = getRunById(runId);
    if (!run) { showNotFound(); return; }

    loadingEl?.classList.add('hidden');
    reportEl?.classList.remove('hidden');

    // Header
    (document.getElementById('report-title') as HTMLElement).textContent = run.templateName;
    (document.getElementById('report-template') as HTMLElement).textContent = run.templateName;
    (document.getElementById('report-operator') as HTMLElement).textContent = run.operatorName;
    (document.getElementById('report-started') as HTMLElement).textContent = formatDate(run.startedAt);
    (document.getElementById('report-completed') as HTMLElement).textContent = run.completedAt ? formatDate(run.completedAt) : 'In Progress';
    
    const dur = run.completedAt
      ? formatDuration(new Date(run.completedAt).getTime() - new Date(run.startedAt).getTime())
      : 'N/A';
    (document.getElementById('report-duration') as HTMLElement).textContent = dur;

    // Stats
    const completed = run.steps.filter(s => s.status === 'complete').length;
    const skipped = run.steps.filter(s => s.status === 'skipped').length;
    let passCount = 0, failCount = 0, naCount = 0;
    for (const step of run.steps) {
      const allCaptured = [...step.captured, ...step.subtasks.flatMap(sub => sub.captured)];
      for (const c of allCaptured) {
        if (c.value === 'Pass') passCount++;
        else if (c.value === 'Fail') failCount++;
        else if (c.value === 'N-A') naCount++;
      }
    }

    (document.getElementById('sum-total') as HTMLElement).textContent = String(run.steps.length);
    (document.getElementById('sum-completed') as HTMLElement).textContent = String(completed);
    (document.getElementById('sum-skipped') as HTMLElement).textContent = String(skipped);
    (document.getElementById('sum-pass') as HTMLElement).textContent = String(passCount);
    (document.getElementById('sum-fail') as HTMLElement).textContent = String(failCount);
    (document.getElementById('sum-na') as HTMLElement).textContent = String(naCount);

    // Radial pass rate
    const totalToggle = passCount + failCount;
    const passRate = totalToggle > 0 ? Math.round((passCount / totalToggle) * 100) : 0;
    const passRateEl = document.getElementById('pass-rate-circle');
    if (passRateEl) {
      const color = passRate >= 80 ? 'text-success' : passRate >= 50 ? 'text-warning' : 'text-error';
      passRateEl.className = `radial-progress font-bold ${color}`;
      passRateEl.style.setProperty('--value', String(passRate));
      passRateEl.textContent = totalToggle > 0 ? `${passRate}%` : 'N/A';
    }
    if (totalToggle === 0) {
      document.getElementById('pass-rate-radial')?.classList.add('hidden');
    }

    // Runtime-added steps
    const runtimeSteps = run.steps.filter(s => s.addedAtRuntime);
    if (runtimeSteps.length > 0) {
      document.getElementById('runtime-steps-alert')?.classList.remove('hidden');
      const list = document.getElementById('runtime-steps-list');
      if (list) {
        list.textContent = runtimeSteps.map(s => s.title).join(', ');
      }
    }

    // Timeline step details
    const timeline = document.getElementById('steps-timeline');
    if (!timeline) return;

    run.steps.forEach((step, idx) => {
      const isComplete = step.status === 'complete';
      const isSkipped = step.status === 'skipped';

      const statusBadgeClass = isComplete ? 'badge-success' : isSkipped ? 'badge-warning' : 'badge-ghost';
      const iconColor = isComplete ? 'text-success' : isSkipped ? 'text-warning' : 'text-base-content/30';

      let fieldsHtml = '';
      if (step.captured.length > 0) {
        fieldsHtml += '<table class="table table-xs w-full mb-2"><thead><tr><th>Field</th><th>Value</th></tr></thead><tbody>';
        for (const c of step.captured) {
          const field = step.fields.find(f => f.id === c.fieldId);
          const rawVal = Array.isArray(c.value) ? c.value.join(', ') : String(c.value);
          const valClass = rawVal === 'Pass' ? 'text-success font-semibold' : rawVal === 'Fail' ? 'text-error font-semibold' : rawVal === 'N-A' ? 'text-warning font-semibold' : '';
          fieldsHtml += `<tr><td class="font-medium text-xs">${field?.label ?? c.fieldId}</td><td class="${valClass} text-xs">${rawVal}</td></tr>`;
        }
        fieldsHtml += '</tbody></table>';
      }

      for (const sub of step.subtasks) {
        if (sub.captured.length > 0) {
          fieldsHtml += `<div class="font-semibold text-xs mt-3 mb-1 text-base-content/60 uppercase tracking-wide">${sub.title}</div>`;
          fieldsHtml += '<table class="table table-xs w-full mb-2"><thead><tr><th>Field</th><th>Value</th></tr></thead><tbody>';
          for (const c of sub.captured) {
            const field = sub.fields.find(f => f.id === c.fieldId);
            const rawVal = Array.isArray(c.value) ? c.value.join(', ') : String(c.value);
            const valClass = rawVal === 'Pass' ? 'text-success font-semibold' : rawVal === 'Fail' ? 'text-error font-semibold' : rawVal === 'N-A' ? 'text-warning font-semibold' : '';
            fieldsHtml += `<tr><td class="font-medium text-xs">${field?.label ?? c.fieldId}</td><td class="${valClass} text-xs">${rawVal}</td></tr>`;
          }
          fieldsHtml += '</tbody></table>';
        }
      }

      const notesHtml = step.notes
        ? `<div class="mt-2 text-xs"><span class="font-medium text-base-content/60">Notes:</span> <span class="text-base-content/70">${step.notes}</span></div>`
        : '';

      const runtimeBadge = step.addedAtRuntime
        ? '<span class="badge badge-warning badge-xs ml-1">+ runtime</span>'
        : '';

      const timingHtml = (step.startedAt || step.completedAt)
        ? `<div class="text-xs text-base-content/40 mt-1">
            ${step.startedAt ? `Started: ${formatDate(step.startedAt)}` : ''}
            ${step.completedAt ? ` · Done: ${formatDate(step.completedAt)}` : ''}
          </div>`
        : '';

      const li = document.createElement('li');
      const isLast = idx === run.steps.length - 1;
      li.innerHTML = `
        ${idx > 0 ? '<hr />' : ''}
        <div class="timeline-middle">
          <div class="w-8 h-8 rounded-full flex items-center justify-center border-2 ${
            isComplete
              ? 'bg-success border-success text-success-content'
              : isSkipped
              ? 'bg-warning/20 border-warning text-warning'
              : 'bg-base-200 border-base-300 text-base-content/30'
          }">
            ${isComplete
              ? `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>`
              : isSkipped
              ? `<span class="text-xs font-bold">⊘</span>`
              : `<span class="text-xs font-bold">${idx + 1}</span>`
            }
          </div>
        </div>
        <div class="timeline-end timeline-box mb-4 max-w-none w-full">
          <div class="flex items-center gap-2 flex-wrap mb-2">
            <span class="font-semibold text-sm">${idx + 1}. ${step.title}</span>
            <span class="badge badge-ghost badge-xs">${step.type}</span>
            <span class="badge ${statusBadgeClass} badge-xs">${step.status}</span>
            ${runtimeBadge}
          </div>
          ${timingHtml}
          ${fieldsHtml || '<div class="text-xs text-base-content/40 mt-1">No data captured</div>'}
          ${notesHtml}
        </div>
      `;
      timeline.appendChild(li);
    });

    // Action buttons
    document.documentElement.setAttribute('data-print-date', new Date().toLocaleDateString());

    document.getElementById('print-btn')?.addEventListener('click', () => {
      console.log('[report] print-btn clicked', { runId: run.runId });
      document.documentElement.setAttribute('data-print-date', new Date().toLocaleDateString());
      window.print();
    });

    document.getElementById('export-json-btn')?.addEventListener('click', () => {
      console.log('[report] export-json-btn clicked', { runId: run.runId });
      exportRunAsJSON(run);
    });

    document.getElementById('export-md-btn')?.addEventListener('click', () => {
      console.log('[report] export-md-btn clicked', { runId: run.runId });
      const md = exportRunAsMarkdown(run);
      const blob = new Blob([md], { type: 'text/markdown' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `run_${run.runId}.md`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  renderReport();
</script>
